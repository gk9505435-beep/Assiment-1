n","import matplotlib.pyplot as plt\n","# Read the image from the file \"sample.jpg\"\n","# cv2.imread() loads the image in BGR (Blue, Green, Red) format by default\n","image = cv2.imread(\"sample.jpg\")\n","# Convert the image from BGR format to RGB format\n","# This is important because matplotlib expects images in RGB format\n","image = cv2.cvtColor(image, cv2.COLOR_BGR2RGB)\n","# Display the image using matplotlib\n","plt.imshow(image)\n","# Add a title to the displayed image\n","plt.title(\"Original Image\")\n","# Turn off axis (removes x and y axis numbers for a cleaner look)\n","plt.axis(\"off\")"]},{"cell_type":"code","source":["print(f\"Pixel value at (100,100): {image[100, 100]}\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"SDQEdbLPqesi","executionInfo":{"status":"ok","timestamp":1774671530002,"user_tz":-330,"elapsed":6,"user":{"displayName":"Gokul Krishnan","userId":"11078006927585760584"}},"outputId":"3e9fe5af-b24b-4d09-8f35-a71404bf1a3b"},"execution_count":4,"outputs":[{"output_type":"stream","name":"stdout","text":["Pixel value at (100,100): [  0   0 212]\n"]}]},{"cell_type":"code","source":["# Convert the original RGB image into a grayscale image\n","# Grayscale means the image will have only intensity (brightness) values\n","# No colors – just shades of black, white, and gray\n","gray = cv2.cvtColor(image, cv2.COLOR_RGB2GRAY)\n","\n","# Display the grayscale image using matplotlib\n","# cmap='gray' tells matplotlib to show the image in grayscale format\n","plt.imshow(gray, cmap='gray')\n","\n","# Add a title to the image\n","plt.title(\"Grayscale Image\")\n","\n","# Turn off axis (removes x and y axis numbers for a cleaner view)\n","plt.axis('off')"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":445},"id":"KU3Rb7i6qqT3","executionInfo":{"status":"ok","timestamp":1774671560735,"user_tz":-330,"elapsed":402,"user":{"displayName":"Gokul Krishnan","userId":"11078006927585760584"}},"outputId":"2e7414a2-e4b7-47a7-fbc4-9cba055c730c"},"execution_count":5,"outputs":[{"output_type":"execute_result","data":{"text/plain":["(np.float64(-0.5), np.float64(799.5), np.float64(599.5), np.float64(-0.5))"]},"metadata":{},"execution_count":5},{"output_type":"display_data","data":{"text/plain":["<Figure size 640x480 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":["# Get image dimensions\n","# image.shape returns (height, width, channels)\n","# h = height (number of rows), w = width (number of columns), _ = color channels (RGB)\n","h, w, _ = image.shape\n","\n","# Crop center region safely (no out-of-bounds)\n","# We are selecting a portion of the image using slicing\n","\n","# int(h*0.2) to int(h*0.7) → selects rows from 20% to 70% of the height\n","# int(w*0.2) to int(w*0.7) → selects columns from 20% to 70% of the width\n","\n","# This effectively crops a central portion of the image\n","# Using percentages ensures we stay within bounds (no index errors)\n","crop = image[int(h*0.2):int(h*0.7), int(w*0.2):int(w*0.7)]\n","\n","# Display\n","# Import matplotlib (used for displaying images)\n","import matplotlib.pyplot as plt# Display the cropped image\n","plt.imshow(crop)\n","\n","# Add a title\n","plt.title(\"Cropped Image\")\n","\n","# Turn off axis for cleaner look\n","plt.axis('off')"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":445},"id":"GIkuREpmq1SG","executionInfo":{"status":"ok","timestamp":1774671589015,"user_tz":-330,"elapsed":440,"user":{"displayName":"Gokul Krishnan","userId":"11078006927585760584"}},"outputId":"7fd1c255-2c56-4fd3-e5f5-f9baed5dd2c6"},"execution_count":6,"outputs":[{"output_type":"execute_result","data":{"text/plain":["(np.float64(-0.5), np.float64(399.5), np.float64(299.5), np.float64(-0.5))"]},"metadata":{},"execution_count":6},{"output_type":"display_data","data":{"text/plain":["<Figure size 640x480 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":["# Apply Canny Edge Detection\n","# 100 = lower threshold, 200 = upper threshold\n","edges = cv2.Canny(gray, 100, 200)\n","\n","# Display the edges\n","plt.imshow(edges, cmap='gray')\n","plt.title('Edge Detection')\n","\n","# Remove axis for clean output\n","plt.axis('off')"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":445},"id":"roDkInFfq80P","executionInfo":{"status":"ok","timestamp":1774671817826,"user_tz":-330,"elapsed":277,"user":{"displayName":"Gokul Krishnan","userId":"11078006927585760584"}},"outputId":"9e215d7d-71ef-4f34-a11c-5a22a5f23bf6"},"execution_count":8,"outputs":[{"output_type":"execute_result","data":{"text/plain":["(np.float64(-0.5), np.float64(799.5), np.float64(599.5), np.float64(-0.5))"]},"metadata":{},"execution_count":8},{"output_type":"display_data","data":{"text/plain":["<Figure size 640x480 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]}]}